{
  "components/common/language-selector-mobile": "<a class=\"navPages-action has-subMenu\"\n   href=\"#\"\n   data-locale-code=\"{{language_selector.active_language_code}}\"\n   data-collapsible=\"navPages-locale\"\n   aria-controls=\"navPages-locale\"\n   aria-expanded=\"false\"\n   aria-label=\"{{language_selector.active_language_code}}\"\n>\n    <span>\n        {{lang 'common.locale'}} <strong>{{language_selector.active_language_code}}</strong>\n    </span>\n    <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n        <svg>\n            <use href=\"#icon-chevron-down\"></use>\n        </svg>\n    </i>\n</a>\n<div class=\"navPage-subMenu\" id=\"navPages-locale\" aria-hidden=\"true\" tabindex=\"-1\">\n    <ul class=\"navPage-subMenu-list\">\n        {{#each language_selector.languages}}\n            <li class=\"navPage-subMenu-item\">\n                <a class=\"navPage-subMenu-action navPages-action\"\n                   href=\"{{switch_url}}\"\n                   data-locale-code=\"{{{code}}}\"\n                   data-warning=\"{{lang 'common.locale_switch_warning'}}\"\n                   aria-label=\"{{code}}\"\n                >\n                    {{#if is_active}}\n                        <strong>{{code}}</strong>\n                    {{else}}\n                        {{code}}\n                    {{/if}}\n                </a>\n            </li>\n        {{/each}}\n    </ul>\n</div>\n"
}