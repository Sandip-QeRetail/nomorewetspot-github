{
  "components/common/language-selector": "<ul class=\"navUser-section\">\n    <li class=\"navUser-item\">\n        <a class=\"navUser-action navUser-action--languageSelector has-dropdown\"\n           href=\"#\"\n           data-locale-code=\"{{language_selector.active_language_code}}\"\n           data-dropdown=\"languageSelection\"\n           aria-controls=\"languageSelection\"\n           aria-expanded=\"false\"\n           aria-label=\"{{language_selector.active_language_code}}\"\n        >\n            {{lang 'common.locale'}} <strong>{{language_selector.active_language_code}}</strong>\n            <i class=\"icon\" aria-hidden=\"true\">\n                <svg>\n                    <use href=\"#icon-chevron-down\" />\n                </svg>\n            </i>\n        </a>\n        <ul class=\"dropdown-menu\" id=\"languageSelection\" data-dropdown-content aria-hidden=\"true\" tabindex=\"-1\">\n            {{#each language_selector.languages}}\n                <li class=\"dropdown-menu-item\">\n                    <a href=\"{{switch_url}}\"\n                       data-locale-code=\"{{code}}\"\n                       data-warning=\"{{lang 'common.locale_switch_warning'}}\"\n                       aria-label=\"{{code}}\"\n                    >\n                        {{#if is_active}}\n                            <strong>{{code}}</strong>\n                        {{else}}\n                            {{code}}\n                        {{/if}}\n                    </a>\n                </li>\n            {{/each}}\n        </ul>\n    </li>\n</ul>\n"
}